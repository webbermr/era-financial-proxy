# Copy this file to .env and fill in your values
# DO NOT commit .env to git

# Your Era Context API key
# Get it from: https://era.app/settings/api  (or Settings → Developer → API Keys)
ERA_API_KEY=your_era_api_key_here

# Era Context MCP server URL (default is correct, only change if self-hosting)
ERA_BASE_URL=https://context.era.app

# Port the proxy listens on locally (Railway/Render set this automatically)
PORT=3001
